# Auto-detect text files and normalize line endings
* text=auto

# Node modules - don't touch these
node_modules/** -text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.otf binary
*.mp4 binary
*.webm binary
*.zip binary
*.tar binary
*.gz binary
*.exe binary
